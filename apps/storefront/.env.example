# ── Storefront env (Next.js) ──────────────────────────────────────────────────
# Copy to .env.local and fill in. NEVER commit real values. NEVER put the
# service-role key here — the storefront only ever uses the anon key + RLS.

# Supabase (public — safe to expose; RLS is the gate)
NEXT_PUBLIC_SUPABASE_URL=https://gvaknqkaooqmtyvknyik.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Canonical site URL (used for SEO/OG, sitemap, JSON-LD, product links in WhatsApp messages)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Analytics (PRD §9) — leave blank to disable in dev
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_META_PIXEL_ID=
